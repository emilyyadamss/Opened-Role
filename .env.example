# Copy this file to .env.local and fill in the values from your Supabase project.
# Project Settings → API.

# Used by the browser app (safe to expose — RLS protects the data):
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Used ONLY by the seed script (scripts/seed.mts). Never expose this in the browser.
# Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
